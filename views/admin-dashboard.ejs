<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | ACT Ministry</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <style>
    body { background: var(--off-white); }
    .admin-nav {
      background: var(--deep-blue);
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--white);
    }
    .admin-nav h2 { font-family: var(--font-heading); color: var(--gold); }
    .btn-logout { background: var(--magenta); color: var(--white); padding: 8px 16px; border-radius: 5px; font-weight: bold; }
    
    .dashboard-container {
      display: grid;
      grid-template-columns: 250px 1fr;
      min-height: calc(100vh - 70px);
    }
    
    .sidebar {
      background: var(--white);
      padding: 20px;
      border-right: 1px solid var(--gray-light);
    }
    .sidebar ul { list-style: none; padding: 0; }
    .sidebar li { margin-bottom: 10px; }
    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px;
      color: var(--text-dark);
      border-radius: var(--radius-sm);
      font-weight: 500;
      transition: var(--transition);
    }
    .sidebar a:hover, .sidebar a.active {
      background: var(--gold);
      color: var(--deep-blue);
    }
    
    .content { padding: 40px; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    
    .card {
      background: var(--white);
      padding: 30px;
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
      margin-bottom: 30px;
    }
    .card h3 { margin-bottom: 20px; color: var(--deep-blue); font-family: var(--font-heading); font-size: 1.5rem; }
    
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-weight: 600; margin-bottom: 8px; font-size: 0.9rem; }
    .form-group input, .form-group textarea {
      width: 100%; padding: 12px; border: 1px solid var(--gray-light); border-radius: 5px; font-family: var(--font-body);
    }
    .form-group textarea { min-height: 100px; resize: vertical; }
    .btn-save {
      background: var(--deep-blue); color: var(--white); padding: 12px 24px; border: none; border-radius: 5px; cursor: pointer; font-weight: bold;
    }
    
    .data-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    .data-table th, .data-table td { padding: 12px; text-align: left; border-bottom: 1px solid var(--gray-light); }
    .data-table th { background: var(--off-white); font-weight: 600; }
    .btn-delete { background: var(--magenta); color: var(--white); padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem; }
    
    .gallery-grid-admin { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px; margin-top: 20px; }
    .gallery-item-admin { position: relative; border-radius: 8px; overflow: hidden; height: 150px; }
    .gallery-item-admin img { width: 100%; height: 100%; object-fit: cover; }
    .gallery-item-admin .btn-delete { position: absolute; top: 5px; right: 5px; padding: 4px 8px; }
    
    .alert { padding: 15px; background: #d4edda; color: #155724; border-radius: 5px; margin-bottom: 20px; border: 1px solid #c3e6cb; }
    
    .drag-drop-zone {
      border: 2px dashed var(--gold); border-radius: var(--radius-md); padding: 40px;
      text-align: center; background: #fafafa; cursor: pointer; transition: all 0.3s; margin-bottom: 15px;
    }
    .drag-drop-zone.dragover { background: #eef2ff; border-color: var(--deep-blue); }
    .drag-drop-zone i { font-size: 3rem; color: var(--gold); }
    .drag-drop-zone p { margin-top: 10px; font-family: var(--font-body); color: var(--text-dark); }

  </style>
</head>
<body>

  <nav class="admin-nav">
    <h2>ACT Dashboard</h2>
    <a href="/admin/logout" class="btn-logout">Logout</a>
  </nav>

  <div class="dashboard-container">
    <aside class="sidebar">
      <ul>
        <li><a href="#" class="tab-btn active" data-target="settings"><i class='bx bx-cog'></i> General Settings</a></li>
        <li><a href="#" class="tab-btn" data-target="events"><i class='bx bx-calendar'></i> Events</a></li>
        <li><a href="#" class="tab-btn" data-target="ministries"><i class='bx bxs-church'></i> Ministries</a></li>
        <li><a href="#" class="tab-btn" data-target="gallery"><i class='bx bx-image'></i> Media Hub</a></li>
        <li><a href="#" class="tab-btn" data-target="sermons"><i class='bx bx-video'></i> Sermons</a></li>
        <li><a href="#" class="tab-btn" data-target="messages"><i class='bx bx-envelope'></i> Messages</a></li>
        <li><a href="#" class="tab-btn" data-target="leadership"><i class='bx bx-group'></i> Leadership</a></li>
        <li><a href="/" target="_blank" style="margin-top: 20px; border: 1px solid var(--deep-blue);"><i class='bx bx-link-external'></i> View Site</a></li>
      </ul>
    </aside>

    <main class="content">
      <% if (msg) { %>
        <div class="alert"><%= msg %></div>
      <% } %>

      <!-- SETTINGS TAB -->
      <section id="settings" class="tab-content active">
        
        <div class="card">
          <h3>Global Hero Banner</h3>
          <p style="font-size: 0.9rem; color: #666; margin-bottom: 15px;">The background image used at the top of the Homepage, Leadership, and Sermons pages.</p>
          
          <div style="margin-bottom: 20px;">
            <img src="<%= data.settings.hero_banner_url || '/images/worship-flyer.png' %>" alt="Current Hero Banner" style="width: 100%; max-height: 250px; object-fit: cover; border-radius: 8px; border: 1px solid var(--gray-light);">
          </div>

          <form action="/admin/settings/hero" method="POST" enctype="multipart/form-data" style="margin-bottom: 15px;">
            <div class="drag-drop-zone" onclick="document.getElementById('heroFileInput').click()" ondragover="event.preventDefault(); this.style.borderColor='var(--magenta)';" ondrop="event.preventDefault(); this.style.borderColor='var(--gray)'; const file = event.dataTransfer.files[0]; if(file) { document.getElementById('heroFileInput').files = event.dataTransfer.files; this.querySelector('span').innerHTML = '<span style=\'color:green;font-weight:600;\'>Ready to upload: ' + file.name + '</span>'; }" style="margin-bottom: 15px;">
              <i class='bx bx-cloud-upload'></i>
              <span>Drag & Drop a new image here or click to browse</span>
              <input type="file" name="hero_image" id="heroFileInput" accept="image/*" style="display: none;" onchange="this.previousElementSibling.innerHTML = '<span style=\'color:green;font-weight:600;\'>Ready to upload: ' + this.files[0].name + '</span>'" required>
            </div>
            <button type="submit" class="btn-save" style="width: auto;"><i class='bx bx-upload'></i> Upload & Replace Banner</button>
          </form>

          <form action="/admin/settings/hero/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete the custom banner and revert to the default placeholder?');">
            <button type="submit" class="btn-delete" style="width: auto; background: rgba(214, 51, 132, 0.1); color: var(--magenta);"><i class='bx bx-reset'></i> Revert to Default</button>
          </form>
        </div>

        <div class="card">
          <h3>General Settings & Text</h3>
          <form action="/admin/settings" method="POST">
            <div class="form-group">
              <label>Hero Title</label>
              <input type="text" name="hero_title" value="<%= data.settings.hero_title %>">
              <small style="color: grey;">Use &lt;span&gt;Worship&lt;/span&gt; for the gold text effect.</small>
            </div>
            <div class="form-group">
              <label>Hero Subtitle</label>
              <input type="text" name="hero_subtitle" value="<%= data.settings.hero_subtitle %>">
            </div>
            <div class="form-group">
              <label>Watch Live Link (YouTube, Facebook, etc.)</label>
              <input type="url" name="watch_live_link" value="<%= data.settings.watch_live_link || 'https://www.youtube.com' %>" placeholder="https://www.youtube.com">
            </div>
            <div class="form-group">
              <label>About Us Text (HTML allowed)</label>
              <textarea name="about_text"><%= data.settings.about_text %></textarea>
            </div>
            <div class="form-group">
              <label>Contact Address</label>
              <input type="text" name="contact_address" value="<%= data.settings.contact_address %>">
            </div>
            <div class="form-group">
              <label>Phone Number 1 (WhatsApp)</label>
              <input type="text" name="contact_phone1" value="<%= data.settings.contact_phone1 %>">
            </div>
            <div class="form-group">
              <label>Main Email</label>
              <input type="email" name="contact_email" value="<%= data.settings.contact_email %>">
            </div>
            <div class="form-group">
              <label>Paystack Public Key (For Donations)</label>
              <input type="text" name="paystack_public_key" value="<%= data.settings.paystack_public_key || '' %>" placeholder="pk_test_...">
              <small style="color: grey;">Leave blank to disable donations.</small>
            </div>
            <button type="submit" class="btn-save">Save Settings</button>
          </form>
        </div>
      </section>

      <!-- EVENTS TAB -->
      <section id="events" class="tab-content">

        <div class="card">
          <h3>Event Section Flyer / Image</h3>
          <p style="font-size: 0.9rem; color: #666; margin-bottom: 15px;">The promotional image displayed next to your Event Cards on the Homepage.</p>
          
          <div style="margin-bottom: 20px;">
            <img src="<%= data.settings.event_flyer_url || '/images/worship-flyer.png' %>" alt="Current Event Flyer" style="width: 100%; max-height: 300px; object-fit: contain; border-radius: 8px; border: 1px solid var(--gray-light); background: #f8f8f8;">
          </div>

          <form action="/admin/events/flyer" method="POST" enctype="multipart/form-data" style="margin-bottom: 15px;">
            <div class="drag-drop-zone" onclick="document.getElementById('eventFlyerInput').click()" ondragover="event.preventDefault(); this.style.borderColor='var(--magenta)';" ondragleave="this.style.borderColor='var(--gray)';" ondrop="event.preventDefault(); this.style.borderColor='var(--gray)'; const file = event.dataTransfer.files[0]; if(file) { document.getElementById('eventFlyerInput').files = event.dataTransfer.files; this.querySelector('span').innerHTML = '<span style=\'color:green;font-weight:600;\'>Ready to upload: ' + file.name + '</span>'; }" style="margin-bottom: 15px;">
              <i class='bx bx-cloud-upload'></i>
              <span>Drag & Drop a new flyer image here or click to browse</span>
              <input type="file" name="flyer_image" id="eventFlyerInput" accept="image/*" style="display: none;" onchange="this.previousElementSibling.innerHTML = '<span style=\'color:green;font-weight:600;\'>Ready to upload: ' + this.files[0].name + '</span>'" required>
            </div>
            <button type="submit" class="btn-save" style="width: auto;"><i class='bx bx-upload'></i> Upload & Replace Flyer</button>
          </form>

          <form action="/admin/events/flyer/delete" method="POST" onsubmit="return confirm('Revert to the default flyer image?');">
            <button type="submit" class="btn-delete" style="width: auto; background: rgba(214, 51, 132, 0.1); color: var(--magenta);"><i class='bx bx-reset'></i> Revert to Default</button>
          </form>
        </div>

        <div class="card">
          <h3>Add New Event Card</h3>
          <form action="/admin/events" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
              <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" required>
              </div>
              <div class="form-group">
                <label>Icon Style (calendar, clock, location, phone)</label>
                <input type="text" name="icon" required>
              </div>
            </div>
            <div class="form-group">
              <label>Description</label>
              <textarea name="description" rows="2" required></textarea>
            </div>
            <button type="submit" class="btn-save">Add Event</button>
          </form>
        </div>

        <div class="card">
          <h3>Current Events cards</h3>
          <table class="data-table">
            <tr>
              <th>Title</th>
              <th>Description</th>
              <th>Icon</th>
              <th>Action</th>
            </tr>
            <% data.events.forEach(event => { %>
            <tr>
              <td><strong><%= event.title %></strong></td>
              <td><%= event.description %></td>
              <td><%= event.icon %></td>
              <td>
                <button class="btn-save" style="padding: 6px 12px; font-size: 0.8rem; margin-right: 5px;" onclick="document.getElementById('edit-event-<%= event.id %>').style.display='table-row'">Edit</button>
                <form action="/admin/events/delete/<%= event.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn-delete" onclick="return confirm('Are you sure?')">Delete</button>
                </form>
              </td>
            </tr>
            <!-- Hidden Edit Row for Event -->
            <tr id="edit-event-<%= event.id %>" style="display:none; background: #f9f9f9;">
              <td colspan="4">
                <form action="/admin/events/edit/<%= event.id %>" method="POST" style="display:flex; gap: 10px; align-items:center;">
                  <input type="text" name="title" value="<%= event.title %>" style="padding:5px; flex:1;" required>
                  <input type="text" name="description" value="<%= event.description %>" style="padding:5px; flex:2;" required>
                  <input type="text" name="icon" value="<%= event.icon %>" style="padding:5px; width:100px;" required>
                  <input type="hidden" name="time" value="<%= event.time %>">
                  <input type="hidden" name="location" value="<%= event.location %>">
                  <button type="submit" class="btn-save" style="padding: 6px 12px; font-size: 0.8rem;">Save</button>
                  <button type="button" class="btn-delete" style="padding: 6px 12px; font-size: 0.8rem;" onclick="document.getElementById('edit-event-<%= event.id %>').style.display='none'">Cancel</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </table>
        </div>
      </section>

      <!-- MINISTRIES TAB -->
      <section id="ministries" class="tab-content">
        <div class="card">
          <h3>Add Ministry</h3>
          <form action="/admin/ministries" method="POST">
            <div class="form-group">
              <label>Title</label>
              <input type="text" name="title" required>
            </div>
            <div class="form-group">
              <label>Emoji/Icon (e.g. 🙏, 🎶)</label>
              <input type="text" name="icon" required>
            </div>
            <div class="form-group">
              <label>Description</label>
              <textarea name="description" rows="2" required></textarea>
            </div>
            <button type="submit" class="btn-save">Add Ministry</button>
          </form>
        </div>

        <div class="card">
          <h3>Current Ministries</h3>
          <table class="data-table">
            <tr>
              <th>Icon</th>
              <th>Title</th>
              <th>Description</th>
              <th>Action</th>
            </tr>
            <% data.ministries.forEach(min => { %>
            <tr>
              <td><span style="font-size: 1.5rem;"><%= min.icon %></span></td>
              <td><strong><%= min.title %></strong></td>
              <td><%= min.description %></td>
              <td>
                <button class="btn-save" style="padding: 6px 12px; font-size: 0.8rem; margin-right: 5px;" onclick="document.getElementById('edit-min-<%= min.id %>').style.display='table-row'">Edit</button>
                <form action="/admin/ministries/delete/<%= min.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn-delete" onclick="return confirm('Are you sure?')">Delete</button>
                </form>
              </td>
            </tr>
            <!-- Hidden Edit Row for Ministry -->
            <tr id="edit-min-<%= min.id %>" style="display:none; background: #f9f9f9;">
              <td colspan="4">
                <form action="/admin/ministries/edit/<%= min.id %>" method="POST" style="display:flex; gap: 10px; align-items:center;">
                  <input type="text" name="title" value="<%= min.title %>" style="padding:5px; flex:1;" required>
                  <input type="text" name="description" value="<%= min.description %>" style="padding:5px; flex:2;" required>
                  <input type="text" name="icon" value="<%= min.icon %>" style="padding:5px; width:80px;" required>
                  <button type="submit" class="btn-save" style="padding: 6px 12px; font-size: 0.8rem;">Save</button>
                  <button type="button" class="btn-delete" style="padding: 6px 12px; font-size: 0.8rem;" onclick="document.getElementById('edit-min-<%= min.id %>').style.display='none'">Cancel</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </table>
        </div>
      </section>

      <!-- MEDIA GALLERY TAB (Drag & Drop) -->
      <section id="gallery" class="tab-content">
        <div class="card">
          <h3>Upload Media (Images & Videos)</h3>
          <form action="/admin/gallery" method="POST" enctype="multipart/form-data">
            <div class="drag-drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
              <i class='bx bx-cloud-upload'></i>
              <p>Drag & Drop Images/Videos here or click to browse</p>
              <input type="file" name="image" id="fileInput" accept="image/*,video/*" style="display: none;" required>
            </div>
            <div id="filePreview" style="margin-bottom:15px; font-weight:bold; color:var(--deep-blue);"></div>
            <div class="form-group">
              <label>Caption text (shows on hover)</label>
              <input type="text" name="caption" required>
            </div>
            <button type="submit" class="btn-save">Upload Media</button>
          </form>
        </div>

        <div class="card">
          <h3>Current Media Files</h3>
          <div class="gallery-grid-admin">
            <% data.gallery.forEach(img => { %>
              <div class="gallery-item-admin" style="position: relative;">
                <% if(img.image_url.match(/\.(mp4|webm|ogg)$/i)) { %>
                  <video src="<%= img.image_url %>" style="width:100%; height:100%; object-fit:cover;" muted></video>
                <% } else { %>
                  <img src="<%= img.image_url %>" alt="<%= img.caption %>">
                <% } %>
                
                <!-- Action Buttons Overlay -->
                <div style="position: absolute; top: 10px; right: 10px; display: flex; gap: 5px;">
                  <button type="button" class="btn-save" style="padding: 5px 8px; font-size: 1rem; border-radius: 4px;" onclick="document.getElementById('edit-gallery-<%= img.id %>').style.display='flex'" title="Edit">
                    <i class='bx bx-edit'></i>
                  </button>
                  <form action="/admin/gallery/delete/<%= img.id %>" method="POST" style="margin:0;">
                    <button type="submit" class="btn-delete" style="padding: 5px 8px; font-size: 1rem; border-radius: 4px;" onclick="return confirm('Delete this media?')" title="Delete"><i class='bx bx-trash'></i></button>
                  </form>
                </div>

                <!-- Hidden Edit Overlay -->
                <div id="edit-gallery-<%= img.id %>" style="display:none; position: absolute; inset: 0; background: rgba(255,255,255,0.95); flex-direction: column; padding: 15px; z-index: 10;">
                  <form action="/admin/gallery/edit/<%= img.id %>" method="POST" enctype="multipart/form-data" style="display:flex; flex-direction:column; height: 100%; gap: 10px;">
                    <h4 style="margin:0; font-size:0.95rem; color:var(--deep-blue);">Edit Media</h4>
                    
                    <label style="font-size:0.8rem; margin-bottom:-5px;">Caption</label>
                    <input type="text" name="caption" value="<%= img.caption %>" style="padding:8px; border:1px solid #ddd; border-radius:4px;" required>
                    
                    <div class="drag-drop-zone" style="flex:1; border: 1px dashed var(--magenta); display:flex; align-items:center; justify-content:center; cursor:pointer; border-radius:4px; background:rgba(214, 51, 132, 0.05); min-height: unset; padding: 10px;" onclick="document.getElementById('gallery-replace-<%= img.id %>').click()" ondragover="event.preventDefault(); this.style.background='rgba(214, 51, 132, 0.1)';" ondrop="event.preventDefault(); this.style.background='rgba(214, 51, 132, 0.05)'; const file = event.dataTransfer.files[0]; if(file) { document.getElementById('gallery-replace-<%= img.id %>').files = event.dataTransfer.files; this.querySelector('span').innerHTML = '<span style=\'color:green;\'>New file: ' + file.name + '</span>'; }">
                      <span style="font-size:0.85rem; text-align:center; font-weight:600; color:var(--magenta);">Drag & Drop or Click<br>to Replace Media</span>
                    </div>
                    <input type="file" name="image" id="gallery-replace-<%= img.id %>" accept="image/*,video/*" style="display:none;" onchange="this.previousElementSibling.querySelector('span').innerHTML = '<span style=\'color:green;\'>New file: ' + this.files[0].name + '</span>'">
                    
                    <div style="display:flex; gap: 5px; margin-top: auto;">
                      <button type="submit" class="btn-save" style="flex:1; padding:8px; font-size:0.85rem;">Save</button>
                      <button type="button" class="btn-delete" style="flex:1; padding:8px; font-size:0.85rem;" onclick="document.getElementById('edit-gallery-<%= img.id %>').style.display='none'">Cancel</button>
                    </div>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <!-- SERMONS TAB -->
      <section id="sermons" class="tab-content">
        <div class="card">
          <h3>Add New Sermon</h3>
          <form action="/admin/sermons" method="POST" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
              <div class="form-group" style="margin-bottom: 0;">
                <label>Sermon Title *</label>
                <input type="text" name="title" required>
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <label>Preacher Name</label>
                <input type="text" name="preacher" placeholder="e.g. Prophet Samuel Eghan Gorman">
              </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 15px;">
              <div class="form-group" style="margin-bottom: 0;">
                <label>Category</label>
                <select name="category" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:4px;">
                  <option value="Faith">Faith</option>
                  <option value="Healing">Healing</option>
                  <option value="Prayer">Prayer</option>
                  <option value="Praise">Praise</option>
                  <option value="Prophecy">Prophecy</option>
                  <option value="Teaching">Teaching</option>
                  <option value="General" selected>General</option>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <label>Date Preached</label>
                <input type="date" name="date_preached">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <label style="display:block;">Featured Sermon?</label>
                <label class="toggle-switch" style="display:inline-block; margin-top:5px;">
                  <input type="checkbox" name="is_featured">
                  <span class="slider"></span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label>Scripture Reference</label>
              <input type="text" name="scripture" placeholder="e.g. John 3:16, Romans 8:28">
            </div>

            <div class="form-group">
              <label>Description *</label>
              <textarea name="description" rows="3" required></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 20px;">
              <!-- Thumbnail -->
              <div class="drag-drop-zone" onclick="document.getElementById('sermonThumbInput').click()" style="min-height:100px; padding:15px; border-color:var(--magenta);">
                <i class='bx bx-image-add' style="font-size: 2rem; margin-bottom: 5px;"></i>
                <p style="font-size:0.85rem; margin:0;">Thumbnail Image (Optional)</p>
                <input type="file" name="thumbnail" id="sermonThumbInput" accept="image/*" style="display: none;" onchange="this.previousElementSibling.innerHTML = '<span style=\'color:green;\'>Selected: ' + this.files[0].name + '</span>'">
              </div>

              <!-- Audio -->
              <div class="drag-drop-zone" onclick="document.getElementById('sermonAudioInput').click()" style="min-height:100px; padding:15px; border-color:var(--deep-blue);">
                <i class='bx bx-microphone' style="font-size: 2rem; margin-bottom: 5px;"></i>
                <p style="font-size:0.85rem; margin:0;">Audio File (Optional)</p>
                <input type="file" name="sermon_audio" id="sermonAudioInput" accept="audio/*" style="display: none;" onchange="this.previousElementSibling.innerHTML = '<span style=\'color:green;\'>Selected: ' + this.files[0].name + '</span>'">
              </div>

              <!-- Video -->
              <div class="drag-drop-zone" onclick="document.getElementById('sermonVideoInput').click()" style="min-height:100px; padding:15px; border-color:var(--gold);">
                <i class='bx bx-video-plus' style="font-size: 2rem; margin-bottom: 5px;"></i>
                <p style="font-size:0.85rem; margin:0;">Video File (.mp4)</p>
                <input type="file" name="sermon_video" id="sermonVideoInput" accept="video/*" style="display: none;" onchange="this.previousElementSibling.innerHTML = '<span style=\'color:green;\'>Selected: ' + this.files[0].name + '</span>'">
              </div>
            </div>

            <div class="form-group">
              <label>— OR — YouTube Embed URL (Overrides video upload)</label>
              <input type="url" name="video_url" placeholder="e.g. https://www.youtube.com/embed/...">
            </div>
            
            <button type="submit" class="btn-save" style="font-size: 1.1rem; padding: 12px;"><i class='bx bx-plus-circle'></i> Add Sermon to Library</button>
          </form>
        </div>

        <div class="card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h3 style="margin: 0;">Sermons Library</h3>
            <div style="position: relative;">
              <i class='bx bx-search' style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--gray);"></i>
              <input type="text" id="adminSermonSearch" placeholder="Search sermons..." style="padding: 8px 10px 8px 30px; border: 1px solid #ddd; border-radius: 4px; width: 250px;" onkeyup="filterAdminSermons()">
            </div>
          </div>

          <div style="overflow-x: auto;">
            <table class="data-table" id="adminSermonsTable">
              <tr>
                <th style="width: 80px;">Media</th>
                <th>Details</th>
                <th>Category</th>
                <th>Date</th>
                <th>Featured</th>
                <th style="width: 150px;">Action</th>
              </tr>
              <% data.sermons.forEach(sermon => { %>
              <tr class="sermon-row">
                <td>
                  <% if(sermon.thumbnail_url) { %>
                    <img src="<%= sermon.thumbnail_url %>" alt="Thumb" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;">
                  <% } else { %>
                    <div style="width: 60px; height: 40px; background: #eee; border-radius: 4px; display: flex; align-items: center; justify-content: center;"><i class='bx bx-video'></i></div>
                  <% } %>
                </td>
                <td>
                  <strong class="s-title"><%= sermon.title %></strong><br>
                  <span style="font-size: 0.8rem; color: #666;"><i class='bx bx-user'></i> <%= sermon.preacher || 'Unknown' %></span>
                </td>
                <td><span class="badge" style="background: var(--light-bg); color: var(--deep-blue); padding: 4px 8px; border-radius: 12px; font-size: 0.8rem;"><%= sermon.category %></span></td>
                <td><%= sermon.date_preached ? new Date(sermon.date_preached).toLocaleDateString() : 'N/A' %></td>
                <td>
                  <% if(sermon.is_featured) { %>
                    <i class='bx bxs-star' style="color: gold; font-size: 1.2rem;" title="Featured"></i>
                  <% } else { %>
                    <i class='bx bx-star' style="color: #ccc; font-size: 1.2rem;"></i>
                  <% } %>
                </td>
                <td>
                  <button class="btn-save" style="padding: 6px 10px; font-size: 0.8rem;" onclick="document.getElementById('edit-sermon-<%= sermon.id %>').style.display='table-row'"><i class='bx bx-edit'></i> Edit</button>
                  <form action="/admin/sermons/delete/<%= sermon.id %>" method="POST" style="display:inline;">
                    <button type="submit" class="btn-delete" style="padding: 6px 10px; font-size: 0.8rem;" onclick="return confirm('Delete this sermon?')"><i class='bx bx-trash'></i></button>
                  </form>
                </td>
              </tr>

              <!-- Inline Edit Row -->
              <tr id="edit-sermon-<%= sermon.id %>" style="display:none; background: #f8fbff;">
                <td colspan="6" style="padding: 15px; border: 1px solid var(--deep-blue);">
                  <form action="/admin/sermons/edit/<%= sermon.id %>" method="POST" enctype="multipart/form-data">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 10px;">
                      <h4 style="margin:0; color:var(--deep-blue);">Edit Sermon</h4>
                      <i class='bx bx-x' style="cursor:pointer; font-size:1.5rem;" onclick="document.getElementById('edit-sermon-<%= sermon.id %>').style.display='none'"></i>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                      <input type="text" name="title" value="<%= sermon.title %>" style="padding:8px;" required>
                      <input type="text" name="preacher" value="<%= sermon.preacher %>" style="padding:8px;" placeholder="Preacher">
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                      <select name="category" style="padding:8px;">
                        <option value="Faith" <%= sermon.category==='Faith'?'selected':'' %>>Faith</option>
                        <option value="Healing" <%= sermon.category==='Healing'?'selected':'' %>>Healing</option>
                        <option value="Prayer" <%= sermon.category==='Prayer'?'selected':'' %>>Prayer</option>
                        <option value="Praise" <%= sermon.category==='Praise'?'selected':'' %>>Praise</option>
                        <option value="Prophecy" <%= sermon.category==='Prophecy'?'selected':'' %>>Prophecy</option>
                        <option value="Teaching" <%= sermon.category==='Teaching'?'selected':'' %>>Teaching</option>
                        <option value="General" <%= sermon.category==='General'?'selected':'' %>>General</option>
                      </select>
                      <input type="text" name="scripture" value="<%= sermon.scripture %>" style="padding:8px;" placeholder="Scripture">
                      <div style="display:flex; align-items:center; gap:10px;">
                        <input type="date" name="date_preached" value="<%= sermon.date_preached ? sermon.date_preached.split('T')[0] : '' %>" style="padding:8px; flex:1;">
                        <label style="font-size:0.8rem; display:flex; align-items:center; gap:5px;"><input type="checkbox" name="is_featured" <%= sermon.is_featured ? 'checked' : '' %>> Featured</label>
                      </div>
                    </div>

                    <textarea name="description" rows="2" style="width:100%; padding:8px; margin-bottom:10px;" required><%= sermon.description %></textarea>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px;">
                      <input type="url" name="video_url" value="<%= sermon.video_url %>" style="padding:8px;" placeholder="YouTube Link (leave empty to keep upload)">
                      <div style="display:flex; gap:10px;">
                        <label style="font-size:0.8rem; flex:1; background:white; border:1px dashed #ccc; padding:5px; text-align:center; cursor:pointer;" title="Replace Thumbnail">
                          <i class='bx bx-image'></i> Thumb <input type="file" name="thumbnail" accept="image/*" style="display:none;" onchange="this.parentElement.style.borderColor='green'">
                        </label>
                        <label style="font-size:0.8rem; flex:1; background:white; border:1px dashed #ccc; padding:5px; text-align:center; cursor:pointer;" title="Replace Video">
                          <i class='bx bx-video'></i> Video <input type="file" name="sermon_video" accept="video/*" style="display:none;" onchange="this.parentElement.style.borderColor='green'">
                        </label>
                        <label style="font-size:0.8rem; flex:1; background:white; border:1px dashed #ccc; padding:5px; text-align:center; cursor:pointer;" title="Replace Audio">
                          <i class='bx bx-microphone'></i> Audio <input type="file" name="sermon_audio" accept="audio/*" style="display:none;" onchange="this.parentElement.style.borderColor='green'">
                        </label>
                      </div>
                    </div>

                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                      <button type="submit" class="btn-save" style="padding: 6px 16px;">Save Changes</button>
                    </div>
                  </form>
                </td>
              </tr>
              <% }) %>
            </table>
          </div>
        </div>
      </section>
      
      <script>
        function filterAdminSermons() {
          const query = document.getElementById('adminSermonSearch').value.toLowerCase();
          const rows = document.querySelectorAll('#adminSermonsTable .sermon-row');
          rows.forEach(row => {
            const title = row.querySelector('.s-title').textContent.toLowerCase();
            row.style.display = title.includes(query) ? '' : 'none';
          });
        }
      </script>

      <!-- MESSAGES TAB -->
      <section id="messages" class="tab-content">
        <div class="card">
          <h3>Contact Form Messages</h3>
          <% if(data.messages && data.messages.length > 0) { %>
            <table class="data-table">
              <tr>
                <th>Date</th>
                <th>Name</th>
                <th>Email</th>
                <th>Message</th>
                <th>Action</th>
              </tr>
              <% data.messages.forEach(msg => { %>
              <tr>
                <td><%= new Date(msg.created_at).toLocaleDateString() %></td>
                <td><strong><%= msg.name %></strong></td>
                <td><a href="mailto:<%= msg.email %>"><%= msg.email %></a></td>
                <td><%= msg.message %></td>
                <td>
                  <form action="/admin/messages/delete/<%= msg.id %>" method="POST" style="display:inline;">
                    <button type="submit" class="btn-delete" onclick="return confirm('Delete message?')">Delete</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </table>
          <% } else { %>
            <p>No messages yet.</p>
          <% } %>
        </div>
      </section>

      <!-- LEADERSHIP TAB -->
      <section id="leadership" class="tab-content">
        <div class="card">
          <h3>Add New Leader</h3>
          <form action="/admin/leaders" method="POST" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
              <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" placeholder="e.g. Prophet Samuel E. Gorman" required>
              </div>
              <div class="form-group">
                <label>Position / Title</label>
                <input type="text" name="position" placeholder="e.g. Senior Pastor" required>
              </div>
            </div>

            <div class="form-group">
              <label>Profile Image</label>
              <div class="drag-drop-zone" id="leaderDropZone" onclick="document.getElementById('leaderFileInput').click()">
                <i class='bx bx-cloud-upload'></i>
                <p>Drag & Drop profile image or click to browse</p>
                <input type="file" name="leader_image" id="leaderFileInput" accept="image/*" style="display: none;">
              </div>
              <div id="leaderFilePreview" style="margin-top:10px; font-weight:bold; color:var(--deep-blue);"></div>
            </div>

            <div class="form-group">
              <label>Short Bio (2-3 lines, shown on cards)</label>
              <textarea name="short_bio" rows="2" placeholder="Brief description of the leader..." required></textarea>
            </div>
            <div class="form-group">
              <label>Full Bio (optional, shown on Featured section)</label>
              <textarea name="full_bio" rows="4" placeholder="Detailed biography..."></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
              <div class="form-group">
                <label>WhatsApp Number (optional)</label>
                <input type="text" name="social_whatsapp" placeholder="e.g. +233547860070">
              </div>
              <div class="form-group">
                <label>Facebook Link (optional)</label>
                <input type="text" name="social_facebook" placeholder="https://facebook.com/...">
              </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
              <div class="form-group">
                <label>Display Order</label>
                <input type="number" name="display_order" value="0" min="0" placeholder="Lower = first">
              </div>
              <div class="form-group">
                <label style="display: flex; align-items: center; gap: 10px; margin-top: 28px;">
                  <input type="checkbox" name="is_featured" style="width: auto; padding: 0;">
                  <span>Featured Leader (spotlight section)</span>
                </label>
              </div>
            </div>

            <button type="submit" class="btn-save">Add Leader</button>
          </form>
        </div>

        <div class="card">
          <h3>Current Leaders</h3>
          <% if(data.leaders && data.leaders.length > 0) { %>
          <table class="data-table">
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Position</th>
              <th>Status</th>
              <th>Order</th>
              <th>Action</th>
            </tr>
            <% data.leaders.forEach(leader => { %>
            <% const socials = typeof leader.social_links === 'string' ? JSON.parse(leader.social_links) : (leader.social_links || {}); %>
            <tr>
              <td>
                <% if(leader.image_url) { %>
                  <img src="<%= leader.image_url %>" alt="<%= leader.name %>" style="width:50px; height:50px; border-radius:50%; object-fit:cover;">
                <% } else { %>
                  <div style="width:50px; height:50px; border-radius:50%; background:var(--gray-light); display:flex; align-items:center; justify-content:center;"><i class='bx bx-user'></i></div>
                <% } %>
              </td>
              <td><strong><%= leader.name %></strong></td>
              <td><%= leader.position %></td>
              <td>
                <% if(leader.is_featured) { %>
                  <span style="background: var(--gold); color: var(--deep-blue); padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 700;">Featured</span>
                <% } else { %>
                  <span style="background: var(--gray-light); color: var(--gray-dark); padding: 3px 10px; border-radius: 12px; font-size: 0.75rem;">Normal</span>
                <% } %>
              </td>
              <td><%= leader.display_order %></td>
              <td>
                <button class="btn-save" style="padding: 6px 12px; font-size: 0.8rem; margin-right: 5px;" onclick="document.getElementById('edit-leader-<%= leader.id %>').style.display='table-row'">Edit</button>
                <form action="/admin/leaders/delete/<%= leader.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this leader?')">Delete</button>
                </form>
              </td>
            </tr>
            <!-- Hidden Edit Row for Leader -->
            <tr id="edit-leader-<%= leader.id %>" style="display:none; background: #f9f9f9;">
              <td colspan="6">
                <form action="/admin/leaders/edit/<%= leader.id %>" method="POST" enctype="multipart/form-data" style="padding: 15px;">
                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                    <input type="text" name="name" value="<%= leader.name %>" placeholder="Name" style="padding:8px;" required>
                    <input type="text" name="position" value="<%= leader.position %>" placeholder="Position" style="padding:8px;" required>
                  </div>
                  <div style="margin-bottom: 10px;">
                    <textarea name="short_bio" rows="2" style="width:100%; padding:8px;" placeholder="Short Bio" required><%= leader.short_bio %></textarea>
                  </div>
                  <div style="margin-bottom: 10px;">
                    <textarea name="full_bio" rows="3" style="width:100%; padding:8px;" placeholder="Full Bio (optional)"><%= leader.full_bio || '' %></textarea>
                  </div>
                  <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                    <div>
                      <label style="font-size:0.8rem; font-weight:600;">New Image (optional)</label>
                      <input type="file" name="leader_image" accept="image/*" style="padding:5px; font-size:0.85rem;">
                    </div>
                    <input type="text" name="social_whatsapp" value="<%= socials.whatsapp || '' %>" placeholder="WhatsApp" style="padding:8px;">
                    <input type="text" name="social_facebook" value="<%= socials.facebook || '' %>" placeholder="Facebook URL" style="padding:8px;">
                  </div>
                  <div style="display: flex; gap: 10px; align-items: center;">
                    <input type="number" name="display_order" value="<%= leader.display_order %>" style="padding:8px; width:80px;" min="0">
                    <label style="display:flex; align-items:center; gap:5px; font-size:0.85rem;">
                      <input type="checkbox" name="is_featured" style="width:auto; padding:0;" <%= leader.is_featured ? 'checked' : '' %>> Featured
                    </label>
                    <button type="submit" class="btn-save" style="padding: 6px 12px; font-size: 0.8rem;">Save</button>
                    <button type="button" class="btn-delete" style="padding: 6px 12px; font-size: 0.8rem;" onclick="document.getElementById('edit-leader-<%= leader.id %>').style.display='none'">Cancel</button>
                  </div>
                </form>
              </td>
            </tr>
            <% }) %>
          </table>
          <% } else { %>
            <p>No leaders added yet. Add your first leader above!</p>
          <% } %>
        </div>
      </section>

    </main>
  </div>

  <script>
    // Simple tab switching logic for the admin dashboard
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', (e) => {
        e.preventDefault();
        
        // Remove active class from all
        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));
        
        // Add active class to clicked
        tab.classList.add('active');
        const target = tab.getAttribute('data-target');
        document.getElementById(target).classList.add('active');
      });
    });

    // Fade out alerts
    setTimeout(() => {
      const alert = document.querySelector('.alert');
      if(alert) {
        alert.style.opacity = '0';
        setTimeout(() => alert.style.display = 'none', 500);
      }
    }, 3000);

    // Drag and Drop Logic
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const filePreview = document.getElementById('filePreview');

    if(dropZone) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, preventDefaults, false);
      });
      function preventDefaults(e) { e.preventDefault(); e.stopPropagation(); }

      ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => dropZone.classList.add('dragover'), false);
      });
      ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => dropZone.classList.remove('dragover'), false);
      });

      dropZone.addEventListener('drop', handleDrop, false);
      function handleDrop(e) {
        let dt = e.dataTransfer;
        let files = dt.files;
        if(files.length > 0) {
          fileInput.files = files; 
          filePreview.textContent = 'Selected file: ' + files[0].name;
        }
      }

      fileInput.addEventListener('change', function() {
        if(this.files.length > 0) {
          filePreview.textContent = 'Selected file: ' + this.files[0].name;
        }
      });
    }

    // Sermon Drag and Drop Logic
    const sermonDropZone = document.getElementById('sermonDropZone');
    const sermonFileInput = document.getElementById('sermonFileInput');
    const sermonFilePreview = document.getElementById('sermonFilePreview');

    if(sermonDropZone) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        sermonDropZone.addEventListener(eventName, preventDefaults, false);
      });
      function preventDefaults(e) { e.preventDefault(); e.stopPropagation(); }

      ['dragenter', 'dragover'].forEach(eventName => {
        sermonDropZone.addEventListener(eventName, () => sermonDropZone.classList.add('dragover'), false);
      });
      ['dragleave', 'drop'].forEach(eventName => {
        sermonDropZone.addEventListener(eventName, () => sermonDropZone.classList.remove('dragover'), false);
      });

      sermonDropZone.addEventListener('drop', handleDrop, false);
      function handleDrop(e) {
        let dt = e.dataTransfer;
        let files = dt.files;
        if(files.length > 0) {
          sermonFileInput.files = files; 
          sermonFilePreview.textContent = 'Selected file: ' + files[0].name;
        }
      }

      sermonFileInput.addEventListener('change', function() {
        if(this.files.length > 0) {
          sermonFilePreview.textContent = 'Selected file: ' + this.files[0].name;
        }
      });
    }

    // Leader Image Drag and Drop Logic
    const leaderDropZone = document.getElementById('leaderDropZone');
    const leaderFileInput = document.getElementById('leaderFileInput');
    const leaderFilePreview = document.getElementById('leaderFilePreview');

    if(leaderDropZone) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        leaderDropZone.addEventListener(eventName, function(e) { e.preventDefault(); e.stopPropagation(); }, false);
      });
      ['dragenter', 'dragover'].forEach(eventName => {
        leaderDropZone.addEventListener(eventName, () => leaderDropZone.classList.add('dragover'), false);
      });
      ['dragleave', 'drop'].forEach(eventName => {
        leaderDropZone.addEventListener(eventName, () => leaderDropZone.classList.remove('dragover'), false);
      });

      leaderDropZone.addEventListener('drop', function(e) {
        let dt = e.dataTransfer;
        let files = dt.files;
        if(files.length > 0) {
          leaderFileInput.files = files;
          leaderFilePreview.textContent = 'Selected: ' + files[0].name;
        }
      }, false);

      leaderFileInput.addEventListener('change', function() {
        if(this.files.length > 0) {
          leaderFilePreview.textContent = 'Selected: ' + this.files[0].name;
        }
      });
    }
  </script>
</body>
</html>
